{
  "name": "vlogkit-electron",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "wait-on http://localhost:3000 && VLOGKIT_DEV_URL=http://localhost:3000 electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder --mac --publish=never"
  },
  "dependencies": {
    "electron": "^32.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "ai.vlogkit.desktop",
    "productName": "vlogkit",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web/out"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg"],
      "identity": null
    },
    "dmg": {
      "artifactName": "vlogkit-${version}.dmg"
    }
  }
}
